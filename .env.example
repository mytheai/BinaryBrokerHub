# Copy this file to .env.local and fill in values from your Supabase project dashboard.
# .env.local is gitignored — never commit it.

# ====== Supabase (Database + Auth) ======
# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Project Settings > API > anon public key
# Safe to expose in browser. Used for public reads (RLS-protected).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Project Settings > API > service_role key
# NEVER expose in browser. Used only in server actions / API routes.
# Bypasses RLS — handle carefully.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ====== Affiliate click hashing ======
# Random string used to salt IP hashing (rotate daily for extra privacy).
# Generate: openssl rand -hex 32
CLICK_HASH_SALT=replace_with_random_64_char_hex

# ====== X (Twitter) API — Social Bot ======
# Get from: https://developer.x.com → Your App → Keys and Tokens
TWITTER_API_KEY=your_consumer_api_key
TWITTER_API_SECRET=your_consumer_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# Protects /api/social/tweet endpoint from unauthorized calls
# Generate: openssl rand -hex 32
CRON_SECRET=replace_with_random_64_char_hex
